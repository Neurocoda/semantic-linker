{
	"name": "semantic-linker",
	"version": "0.1.1",
	"description": "Recommend semantically related notes from local metadata and insert curated links.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "node --import tsx --test tests/*.test.ts",
		"lint": "eslint .",
		"check-release": "npm run build && node scripts/check-release.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"semantic-search",
		"note-linking",
		"embedding"
	],
	"author": "Neurocoda",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Neurocoda/semantic-linker.git"
	},
	"bugs": {
		"url": "https://github.com/Neurocoda/semantic-linker/issues"
	},
	"homepage": "https://github.com/Neurocoda/semantic-linker#readme",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.10.2",
		"esbuild": "0.25.5",
		"eslint": "^9.30.1",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "15.14.0",
		"obsidian": "latest",
		"tslib": "2.8.1",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"minisearch": "^7.1.2"
	}
}
