{
	"name": "semantic-linker",
	"version": "0.1.0",
	"description": "An Obsidian plugin that recommends semantically related notes from local metadata and inserts curated links.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "node --import tsx --test tests/*.test.ts",
		"lint": "eslint .",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"semantic-search",
		"note-linking",
		"embedding"
	],
	"author": "Neurocoda",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.10.2",
		"esbuild": "0.25.5",
		"eslint": "^9.30.1",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "15.14.0",
		"tslib": "2.8.1",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1"
	},
	"dependencies": {
		"minisearch": "^7.1.2",
		"obsidian": "latest"
	}
}
